{#-
Extractors (template-defined):
  - response: AnchorExtractor("<DETAIL>", "</DETAIL>", fallback_to_full=True)
-#}
{#
  TASK: Character Detail Generation
  Generates character detail or answers a character question.
  Handles both question format (ends with ?) and detail format.
#}
{% if context_name.endswith("?") %}
{{ action_task }} answer to "{{ context_name }}" for {{ character_name }}. This must be a general description and not a continuation of the current narrative.

{% with output_tag="DETAIL", output_label="answer" %}{% include "contextual-generate/output-format.jinja2" %}{% endwith %}
{% else %}
{{ action_task }} "{{ context_name }}" detail for {{ character_name }}. This must be a general description and not a continuation of the current narrative. Use paragraphs to separate different details.

{% with output_tag="DETAIL", output_label="detail", output_example="the detail text" %}{% include "contextual-generate/output-format.jinja2" %}{% endwith %}
{% endif %}
