Current outline ({{ outline | length }} beats):

{% for beat in outline %}
Beat {{ loop.index }} [{{ beat.type }}] (pacing: {{ beat.pacing }}, tension: {{ beat.tension }})
  Characters: {{ beat.characters | join(", ") if beat.characters else "none" }}
