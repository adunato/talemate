    "953a9363-d461-4024-aacd-39b904824cd8": {
      "title": "Metadata: roll_dice",
      "id": "953a9363-d461-4024-aacd-39b904824cd8",
      "properties": {
        "instructions": "Roll a random integer between `min` and `max` (inclusive) to resolve a gameplay mechanic such as a skill check, contested action, or chance-driven outcome. Always provide a `reason` describing what is being resolved. Prefer standard die shapes (d4, d6, d8, d10, d12, d20, d100) unless a specific range is more appropriate. Returns a short human-readable summary string of the form `<reason>: rolled <n>` describing the outcome.",
        "examples": [
          {
            "min": 1,
            "max": 20,
            "reason": "Elmer attempts to pick the lock on the gate"
          },
          {
            "min": 1,
            "max": 6,
            "reason": "Surprise check as the party enters the cave"
          },
          {
            "min": 1,
            "max": 100,
            "reason": "Contested arm-wrestling match between Klex and Brug"
          }
        ]
      },
      "x": 1439,
      "y": 1745,
      "width": 210,
      "height": 86,
      "collapsed": false,
      "inherited": false,
