    "0170c645-46d8-4728-87d5-480940730109": {
      "title": "Action Argument: instructions",
      "id": "0170c645-46d8-4728-87d5-480940730109",
      "properties": {
        "name": "instructions",
        "typ": "str",
        "instructions": "A natural-language sentence describing what gameplay action should be resolved. Examples: \"Roll a d20 for Elmer's lockpick attempt\", \"Quick d6 for surprise\", \"Roll between 1 and 100 for the contested arm-wrestling match\". The system parses this sentence and extracts the structured parameters (dice range, reason) for you \u2014 you don't need to format anything."
