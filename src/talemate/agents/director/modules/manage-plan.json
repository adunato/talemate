{
  "title": "Manage Plan",
  "id": "96b7b46f-f3ea-48ba-a934-c7534d399010",
  "properties": {
    "name": "manage_plan",
    "description": "Allows you set up, track and update your current set of tasks. Use this to setup general plans or plans for creating multiple beats of content over a specific number of beats / turns.",
    "instructions": "Manage your task plans. Pass plain text instructions describing what you want to do.\n\nTo create a scene outline: describe the scene and specify the beat count.\nTo create a general plan: describe the goal and list the tasks.\nTo complete a task: state the plan ID and task ID.",
    "example_json": "[{\"instructions\": \"Create a 6-beat scene outline: A tense encounter in the library where two strangers discover they're searching for the same book.\"}, {\"instructions\": \"Mark task a1b2c3d4 as completed in plan 843c4835-3\"}, {\"instructions\": \"Create a plan to investigate the strange signals: 1) Check the antenna array 2) Review the signal logs 3) Report findings to command\"}]"
  },
  "x": 0,
  "y": 0,
  "width": 200,
  "height": 100,
  "collapsed": false,
  "inherited": false,
